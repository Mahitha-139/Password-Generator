import secrets
import string

def generate_password(length):
    # Combine all necessary character sets
    characters = string.ascii_letters + string.digits + string.punctuation
    
    # Generate a cryptographically secure random password
    password = ''.join(secrets.choice(characters) for _ in range(length))
    return password

def main():
    print("Welcome to the Secure Password Generator!")
    
    while True:
        try:
            length_input = input("Enter password length (minimum 8): ")
            length = int(length_input)
            
            if length >= 8:
                break
            else:
                print("Password must be at least 8 characters long for good security.")
        except ValueError:
            print("Please enter a valid integer.")
            
    secure_password = generate_password(length)
    print(f"\nGenerated Password: {secure_password}")

if __name__ == "__main__":
    main()
